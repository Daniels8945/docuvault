# Copy this file to .env and fill in values before running docker-compose

# PostgreSQL
POSTGRES_DB=docuvault
POSTGRES_USER=docuvault
POSTGRES_PASSWORD=change_me_strong_password

# MinIO (S3-compatible file storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=docuvault

# WAHA (WhatsApp HTTP API)
# Set any secret string — all API calls to WAHA must include X-Api-Key: <this value>
WAHA_API_KEY=change_me_waha_secret
